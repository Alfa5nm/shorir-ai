{
  "name": "@shorir/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "pretypecheck": "pnpm --filter @shorir/contracts build && pnpm --filter @shorir/content build",
    "typecheck": "tsc -b --noEmit",
    "prelint": "pnpm --filter @shorir/contracts build && pnpm --filter @shorir/content build",
    "lint": "tsc -b --noEmit",
    "preview": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "@shorir/content": "workspace:*",
    "@shorir/contracts": "workspace:*",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.1",
    "typescript": "^5.8.3",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2"
  }
}
